{
  "manifest_version": 3,
  "name": "CourseWeb Quick Courses",
  "version": "1.2.0",
  "description": "Adds a 'Courses' dropdown to CourseWeb SLIIT navbar for quick access to your tagged course pages.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://courseweb.sliit.lk/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://courseweb.sliit.lk/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "courseweb-quick-courses@chaturnakasturiratna.dev",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
